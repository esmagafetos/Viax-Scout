{
  "expo": {
    "name": "ViaX:Trace",
    "slug": "viax-trace",
    "version": "2.0.0",
    "orientation": "portrait",
    "scheme": "viaxtrace",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#f4f3ef",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.viax.trace"
    },
    "android": {
      "package": "com.viax.trace",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
