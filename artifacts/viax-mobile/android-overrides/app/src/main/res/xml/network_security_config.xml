<?xml version="1.0" encoding="utf-8"?>
<!--
  ViaX:Trace — Network security config

  Este app conecta intencionalmente a um backend que o usuário roda no próprio
  aparelho (Termux) ou em outro dispositivo da mesma Wi-Fi. O usuário digita a
  URL manualmente em "Configurar servidor", então o consentimento é explícito.

  Padrão usado por apps profissionais que falam com servidores em LAN
  (ex.: apps de roteador, smart-home, automação local).

  - base-config: cleartext PERMITIDO globalmente (necessário porque CIDR
    não é suportado em <domain> e seria impossível enumerar todos os IPs
    privados de Wi-Fi). O usuário consente ao digitar a URL.
  - domain-config: enforça TLS para o domínio de produção (Replit) e
    domínios públicos comuns, garantindo que mesmo que o app caia em
    fallback HTTP por engano, ele rejeite a conexão pra esses hosts.
  - trust-anchors: apenas certificados do sistema (sem CAs do usuário,
    pra evitar MITM via certificados instalados manualmente).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">replit.app</domain>
        <domain includeSubdomains="true">replit.dev</domain>
        <domain includeSubdomains="true">repl.co</domain>
    </domain-config>
</network-security-config>
